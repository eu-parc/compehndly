    {
      "id": "random_single_imputation_scalar_input_basic",
      "function": "random_single_imputation_scalar_input",
      "input": {
        "positional": [[5.0, -1.0, -2.0, 10.0, -3.0, 8.0]]
      },
      "params": {"lod": 2.0, "loq": 4.0, "seed": 123},
      "assertions": {
        "non_negative": true,
        "equals_at_indices": {
          "0": 5.0,
          "3": 10.0,
          "5": 8.0
        }
      }
    },
    {
      "id": "random_single_imputation_scalar_input_bounds_respected",
      "function": "random_single_imputation_scalar_input",
      "input": {
        "positional": [[-1.0, -2.0, -3.0, 4.1, 5.2, 6.3, 7.4, 8.5]]
      },
      "params": {"lod": 2.0, "loq": 4.0, "seed": 42},
      "assertions": {
        "ranges_at_indices": {
          "0": [0.0, 2.0],
          "1": [2.0, 4.0],
          "2": [0.0, 4.0]
        },
        "min_value_from_index": {
          "start": 3,
          "value": 4.0
        },
        "no_nan": true
      }
    },
    {
      "id": "random_single_imputation_series_thresholds",
      "function": "random_single_imputation",
      "input": {
        "named": {
          "biomarker": [-1.0, -2.0, -3.0, 5.0, 6.0, 7.0, 8.0],
