{
  "version": "0.0.1",
  "cases": [
    {
      "id": "summation_all_required_true",
      "function": "summation",
      "input": {
        "positional": [[1.0, null, 3.0], [null, 5.0, 1.0], [2.0, 2.0, null]]
      },
      "params": {"all_required": true},
      "assertions": {
        "expected": [3.0, 7.0, 4.0]
      }
    },
    {
      "id": "summation_entire_null_series_returns_all_null",
      "function": "summation",
      "input": {
        "positional": [[1.0, 2.0, 3.0], [null, null, null], [1.0, 1.0, 1.0]]
      },
      "params": {"all_required": true},
      "assertions": {
        "all_null": true
      }
    },
    {
      "id": "summation_not_all_required",
      "function": "summation",
      "input": {
        "positional": [[1.0, null, 3.0], [null, 2.0, null]]
      },
      "params": {"all_required": false},
      "assertions": {
        "expected": [1.0, 2.0, 3.0]
      }
    },
    {
      "id": "summation_length_mismatch_raises",
      "function": "summation",
      "input": {
        "positional": [[1.0, 2.0], [1.0]]
      },
      "expect_error": {
        "type": "ValueError"
      }
    },
    {
      "id": "multiply_by_group_basic",
      "function": "multiply_by_group",
      "input": {
        "named": {
          "factor_1": [2.0, 4.0, 6.0],
          "factor_2": [3.0, 5.0, 7.0],
          "factor_3": [2.0, 10.0, 3.0]
        }
      },
      "params": {
        "invert_3": true
      },
      "assertions": {
        "expected": [3.0, 2.0, 14.0]
      }
    },
    {
      "id": "multiply_by_group_only_inverted_with_scalar",
      "function": "multiply_by_group",
      "input": {
        "named": {
          "factor_1": [2.0, 4.0]
        }
      },
      "params": {
        "invert_1": true,
        "scalar_factor": 10.0
      },
      "assertions": {
        "expected": [5.0, 2.5]
      }
    },
    {
      "id": "multiply_by_group_interleaves_inverse_factors",
      "function": "multiply_by_group",
      "input": {
        "named": {
          "factor_1": [1e200],
          "factor_2": [1e200],
          "factor_3": [1e200]
        }
      },
      "params": {
        "invert_2": true
      },
      "assertions": {
        "expected": [1e200]
      }
    },
    {
      "id": "multiply_by_group_invert_without_factor_raises",
      "function": "multiply_by_group",
      "input": {
        "named": {}
      },
      "params": {
        "invert_1": true
      },
      "expect_error": {
        "type": "ValueError"
      }
    },
    {
      "id": "multiply_by_group_unexpected_argument_raises",
      "function": "multiply_by_group",
      "input": {
        "named": {
          "factor_1": [1.0]
        }
      },
      "params": {
        "factors": "factor_1"
      },
      "expect_error": {
        "type": "ValueError"
      }
    },
    {
      "id": "multiply_by_group_non_contiguous_factor_raises",
      "function": "multiply_by_group",
      "input": {
        "named": {
          "factor_2": [1.0]
        }
      },
      "expect_error": {
        "type": "ValueError"
      }
    },
    {
      "id": "weighted_summation_basic_named",
      "function": "weighted_summation",
      "input": {
        "named": {
          "a": [1.0, null, 3.0],
          "b": [10.0, 20.0, null]
        }
      },
      "params": {
        "weight__a": 2.0,
        "weight__b": 0.5
      },
      "assertions": {
        "expected": [7.0, 10.0, 6.0]
      }
    },
    {
      "id": "weighted_summation_cutoff_any_input_passes",
      "function": "weighted_summation",
      "input": {
        "named": {
          "a": [1.0, null, null, null, null],
          "b": [null, 2.0, 3.0, 4.0, null]
        }
      },
      "params": {
        "weight__a": 10.0,
        "weight__b": 1.0,
        "cutoff": 0.6
      },
      "assertions": {
        "expected": [10.0, 2.0, 3.0, 4.0, 0.0]
      }
    },
    {
      "id": "weighted_summation_missing_weight_raises",
      "function": "weighted_summation",
      "input": {
        "named": {
          "a": [1.0],
          "b": [2.0]
        }
      },
      "params": {
        "weight__a": 1.0
      },
      "expect_error": {
        "type": "ValueError"
      }
    },
