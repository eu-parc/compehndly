          "loq": [4.0, 5.0, 6.0, 4.0, 4.0, 4.0, 4.0]
        }
      },
      "params": {"seed": 42},
      "assertions": {
        "ranges_at_indices": {
          "0": [0.0, 2.0],
          "1": [3.0, 5.0],
          "2": [0.0, 6.0]
        },
