{
  "version": "0.0.1",
  "cases": [
    {
      "id": "summation_all_required_true",
      "function": "summation",
      "input": {
        "positional": [[1.0, null, 3.0], [null, 5.0, 1.0], [2.0, 2.0, null]]
      },
      "params": {"all_required": true},
      "assertions": {
        "expected": [3.0, 7.0, 4.0]
      }
    },
    {
      "id": "summation_entire_null_series_returns_all_null",
      "function": "summation",
      "input": {
        "positional": [[1.0, 2.0, 3.0], [null, null, null], [1.0, 1.0, 1.0]]
      },
      "params": {"all_required": true},
      "assertions": {
        "all_null": true
      }
    },
    {
      "id": "summation_not_all_required",
      "function": "summation",
      "input": {
        "positional": [[1.0, null, 3.0], [null, 2.0, null]]
      },
      "params": {"all_required": false},
      "assertions": {
        "expected": [1.0, 2.0, 3.0]
      }
    },
    {
      "id": "summation_length_mismatch_raises",
      "function": "summation",
      "input": {
        "positional": [[1.0, 2.0], [1.0]]
      },
      "expect_error": {
        "type": "ValueError"
      }
    },
    {
      "id": "standardize_basic",
      "function": "standardize",
      "input": {
        "positional": [[50.0, 100.0, 75.0, 0.0], [25.0, 50.0, 25.0, 10.0]]
      },
      "assertions": {
        "expected": [200.0, 200.0, 300.0, 0.0]
      }
    },
    {
      "id": "standardize_with_nulls",
      "function": "standardize",
      "input": {
        "positional": [[50.0, null, 75.0], [25.0, 50.0, null]]
      },
      "assertions": {
        "expected": [200.0, null, null]
      }
    },
    {
