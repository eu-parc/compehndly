          "copy_from_1": [10.0, 20.0, 30.0, 40.0, 50.0],
          "copy_from_2": [60.0, 70.0, 80.0, 90.0, 100.0]
        }
      },
      "params": {"filter_value_1": -10.0, "filter_value_2": -3.0},
