    {
      "id": "random_single_imputation_basic",
      "function": "random_single_imputation",
      "input": {
        "positional": [[5.0, -1.0, -2.0, 10.0, -3.0, 8.0]]
      },
      "params": {"lod": 2.0, "loq": 4.0, "seed": 123},
      "assertions": {
